# New West Symphony — environment variables
# Copy to .env.local (gitignored) and fill in. All NEXT_PUBLIC_* values are
# inlined into the client bundle at BUILD time, so rebuild after changing them.

# Canonical site origin (audit M2 — required; the build fails if unset in prod).
NEXT_PUBLIC_SITE_URL=https://newwestsymphony.org

# GA4 measurement ID (audit H5). While unset, the consent banner and Google
# Analytics stay completely inert (no tracking). TODO(NWS): set the real ID.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
